---
import ProjectCard from '../components/ProjectCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/site';
---

<BaseLayout
	title="Projects | Consti Ertel"
	description="A selection of machine learning and analytics projects by Consti Ertel."
	activePath="/projects"
>
	<section class="section-grid">
		<div class="projects-hero">
			<div class="section-heading projects-hero__copy">
				<p class="eyebrow">Projects</p>
				<h1>Applied ML and analytics systems designed to be useful, not ornamental.</h1>
				<p class="lede">
					A selection of technical work that sits between research taste and product discipline:
					machine learning experiments, decision tools, and data systems built to clarify real
					choices.
				</p>
			</div>
			<div class="projects-hero__panel card">
				<p class="panel-label">At a glance</p>
				<div class="projects-hero__stats">
					<div>
						<span>05</span>
						<p>featured builds spanning ML, analytics, and product-oriented experimentation.</p>
					</div>
					<div>
						<span>01</span>
						<p>live public application, with the rest documented as research or case-study repos.</p>
					</div>
					<div>
						<span>03</span>
						<p>recurring themes: model usefulness, decision clarity, and systems that survive contact with reality.</p>
					</div>
				</div>
			</div>
		</div>
		<div class="project-stack">
			{projects.map((project, index) => (
				<ProjectCard project={project} index={index} />
			))}
		</div>
	</section>
</BaseLayout>

<style>
	.projects-hero {
		display: grid;
		grid-template-columns: minmax(0, 1.45fr) minmax(18rem, 0.72fr);
		gap: 1.5rem;
		align-items: end;
		margin-bottom: 2rem;
	}

	.projects-hero__copy {
		margin-bottom: 0;
	}

	.projects-hero__panel {
		padding: 1.5rem;
		position: relative;
		overflow: hidden;
	}

	.projects-hero__panel::after {
		content: '';
		position: absolute;
		inset: auto -10% -30% 45%;
		aspect-ratio: 1;
		border-radius: 999px;
		background: radial-gradient(circle, rgba(154, 107, 61, 0.22), transparent 70%);
		pointer-events: none;
	}

	.projects-hero__stats {
		display: grid;
		gap: 1rem;
		position: relative;
		z-index: 1;
	}

	.projects-hero__stats div {
		padding-top: 0.9rem;
		border-top: 1px solid var(--border);
	}

	.projects-hero__stats span {
		display: block;
		font-family: var(--font-serif);
		font-size: clamp(2rem, 4vw, 3rem);
		line-height: 0.9;
		margin-bottom: 0.35rem;
	}

	.projects-hero__stats p {
		margin: 0;
		color: color-mix(in srgb, var(--text) 80%, var(--muted));
		line-height: 1.7;
	}

	.project-stack {
		display: grid;
		gap: 1.25rem;
	}

	@media (max-width: 900px) {
		.projects-hero {
			grid-template-columns: 1fr;
			align-items: stretch;
		}
	}

	@media (max-width: 560px) {
		.projects-hero__panel {
			padding: 1.25rem;
		}
	}
</style>
