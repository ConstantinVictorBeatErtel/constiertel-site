---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/site';
---

<BaseLayout
	title="Projects | Consti Ertel"
	description="A selection of machine learning and analytics projects by Consti Ertel."
	activePath="/projects"
>
	<section class="section-grid">
		<div class="section-heading">
			<p class="eyebrow">Projects</p>
			<h1>Applied ML and analytics systems designed to be useful, not ornamental.</h1>
		</div>
		<div class="project-grid">
			{projects.map((project) => (
				<article class="project-card card">
					<div class="card-meta">
						<span>{project.category}</span>
						<a href={project.href} target="_blank" rel="noreferrer">View link</a>
					</div>
					<h2>{project.title}</h2>
					<p>{project.description}</p>
				</article>
			))}
		</div>
	</section>
</BaseLayout>
