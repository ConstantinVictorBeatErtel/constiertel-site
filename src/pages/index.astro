---
import { getCollection } from 'astro:content';
import ProjectCard from '../components/ProjectCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects, site } from '../data/site';

const research = (await getCollection('research')).sort(
	(a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const featuredResearch = research.slice(0, 2);
const featuredProjects = projects.slice(0, 3);
---

<BaseLayout
	title="Consti Ertel | Research, Analytics, and Projects"
	description="Personal portfolio and equity research platform for Consti Ertel, focused on analytical systems, machine learning, and long-horizon investing."
	activePath="/"
>
	<section class="section-grid">
		<div class="section-heading">
			<p class="eyebrow">About</p>
			<h1>Research-minded builder with a bias for clarity.</h1>
		</div>
		<div class="about-grid">
			<div class="photo-wrap card">
				<img src="/profile.jpg" alt="Constantin Ertel" class="profile-photo" />
			</div>
			<div class="stack">
				<article class="card">
					<h2>Background</h2>
					<p>
						I'm a student at UC Berkeley working at the intersection of machine learning, analytics, and
						investing. I build systems that make hard problems tractable — from self-supervised vision
						experiments and generative model pipelines to Bayesian cost simulations and churn investigations
						on SaaS businesses.
					</p>
				</article>
				<article class="card">
					<h2>Bio</h2>
					<p>
						This site collects equity research, project write-ups, and analytical work. I'm drawn to
						problems that require both quantitative rigor and clear communication — where the goal is to
						be precise about what you know and honest about what you don't. Outside of research and code,
						I follow markets with a long-horizon, durable-moat lens.
					</p>
				</article>
				<article class="card">
					<h2>Links</h2>
					<div class="inline-links">
						{site.socialLinks.map((link) => (
							<a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
						))}
					</div>
				</article>
			</div>
		</div>
	</section>

	<section class="section-grid section-spaced">
		<div class="section-heading">
			<p class="eyebrow">Recent research</p>
			<h2>Editorial stock workups built for patient readers.</h2>
		</div>
		<div class="hero-actions hero-actions--section">
			<a class="button button--primary" href="/research">Read Research</a>
			<a class="button button--secondary" href="/essays">Essays</a>
		</div>
		<div class="stack">
			{featuredResearch.map((entry) => (
				<a class="research-card card" href={`/research/${entry.id}/`}>
					<div class="card-meta">
						<span>{entry.data.ticker}</span>
						<span>{entry.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
					</div>
					<h3>{entry.data.title}</h3>
					<p>{entry.data.summary}</p>
					<div class="tag-row">
						{entry.data.tags.map((tag) => (
							<span class="tag">{tag}</span>
						))}
					</div>
				</a>
			))}
		</div>
	</section>

	<section class="section-grid section-spaced">
		<div class="section-heading">
			<p class="eyebrow">Selected builds</p>
			<h2>Machine learning and analytics projects with production intent.</h2>
		</div>
		<div class="project-grid">
			{featuredProjects.map((project, index) => (
				<ProjectCard project={project} index={index} variant="compact" />
			))}
		</div>
	</section>
</BaseLayout>

<style>
	.photo-wrap {
		aspect-ratio: 4 / 5;
		min-height: 24rem;
		padding: 0;
		overflow: hidden;
	}

	.profile-photo {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center top;
	}

	.hero-actions--section {
		margin-bottom: 1.25rem;
	}
</style>
