---
import { getCollection } from 'astro:content';
import ProjectCard from '../components/ProjectCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects, site } from '../data/site';

const research = (await getCollection('research')).sort(
	(a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const featuredResearch = research.slice(0, 2);
const featuredProjects = projects.slice(0, 3);
---

<BaseLayout
	title="Consti Ertel | Research, Analytics, and Projects"
	description="Personal portfolio and equity research platform for Consti Ertel, focused on analytical systems, machine learning, and long-horizon investing."
	activePath="/"
>
	<section class="hero section-grid">
		<div class="hero-copy">
			<p class="eyebrow">Constiertel</p>
			<h1>{site.name}</h1>
			<p class="lede">{site.tagline}</p>
			<p class="hero-text">
				I build ML systems, publish equity research, and turn messy datasets into decisions worth making.
			</p>
			<div class="hero-actions">
				<a class="button button--primary" href="/research">Read Research</a>
				<a class="button button--secondary" href="/about">About Me</a>
			</div>
		</div>
		<div class="hero-panel card">
			<p class="panel-label">Current focus</p>
			<ul class="signal-list">
				<li>Self-supervised vision and generative model research — building toward deployable ML systems.</li>
				<li>Equity research with a long-horizon, cash-flow-first lens focused on durable business models.</li>
				<li>Data science and ML coursework at UC Berkeley spanning statistics, optimization, and inference.</li>
			</ul>
		</div>
	</section>

	<section class="section-grid section-spaced">
		<div class="section-heading">
			<p class="eyebrow">Recent research</p>
			<h2>Editorial stock workups built for patient readers.</h2>
		</div>
		<div class="stack">
			{featuredResearch.map((entry) => (
				<a class="research-card card" href={`/research/${entry.id}/`}>
					<div class="card-meta">
						<span>{entry.data.ticker}</span>
						<span>{entry.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
					</div>
					<h3>{entry.data.title}</h3>
					<p>{entry.data.summary}</p>
					<div class="tag-row">
						{entry.data.tags.map((tag) => (
							<span class="tag">{tag}</span>
						))}
					</div>
				</a>
			))}
		</div>
	</section>

	<section class="section-grid section-spaced">
		<div class="section-heading">
			<p class="eyebrow">Selected builds</p>
			<h2>Machine learning and analytics projects with production intent.</h2>
		</div>
		<div class="project-grid">
			{featuredProjects.map((project, index) => (
				<ProjectCard project={project} index={index} variant="compact" />
			))}
		</div>
	</section>
</BaseLayout>
