---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const research = (await getCollection('research')).sort(
	(a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<BaseLayout
	title="Research | Consti Ertel"
	description="Equity research articles and stock writeups by Consti Ertel."
	activePath="/research"
>
	<section class="section-grid">
		<div class="section-heading">
			<p class="eyebrow">Research</p>
			<h1>Equity research articles, sorted by conviction and calendar.</h1>
		</div>
		<div class="stack">
			{research.map((entry) => (
				<a class="research-card card" href={`/research/${entry.id}/`}>
					<div class="card-meta">
						<span>{entry.data.ticker}</span>
						<span>{entry.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
					</div>
					<h2>{entry.data.title}</h2>
					<p>{entry.data.summary}</p>
					<div class="tag-row">
						{entry.data.tags.map((tag) => (
							<span class="tag">{tag}</span>
						))}
					</div>
				</a>
			))}
		</div>
	</section>
</BaseLayout>
