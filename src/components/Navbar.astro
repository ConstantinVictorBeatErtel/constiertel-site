---
import ThemeToggle from './ThemeToggle.astro';
import { navLinks, site } from '../data/site';

interface Props {
	activePath?: string;
}

const { activePath = '/' } = Astro.props;
---

<header class="site-header">
	<div class="shell nav-shell">
		<a class="brandmark" href="/">
			<span class="brandmark__name">{site.brand}</span>
			<span class="brandmark__dot"></span>
		</a>
		<nav class="site-nav" aria-label="Primary">
			{navLinks.map((item) => (
				<a class:list={['site-nav__link', activePath === item.href && 'is-active']} href={item.href}>
					{item.label}
				</a>
			))}
		</nav>
		<div class="nav-actions">
			<ThemeToggle />
		</div>
	</div>
</header>
